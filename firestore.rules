rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "alejandralucasimon@gmail.com" && request.auth.token.email_verified == true));
    }

    function isProfileMember(profileId) {
      return isAuthenticated() && 
        (request.auth.uid in get(/databases/$(database)/documents/profiles/$(profileId)).data.members ||
         get(/databases/$(database)/documents/profiles/$(profileId)).data.ownerUid == request.auth.uid);
    }

    function isProfileOwner(profileId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/profiles/$(profileId)).data.ownerUid == request.auth.uid;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidInvestment(data) {
      return hasOnlyAllowedFields(['profileId', 'symbol', 'name', 'shares', 'purchasePrice', 'currentPrice']) &&
             data.profileId is string &&
             data.symbol is string && data.symbol.size() > 0 && data.symbol.size() < 10 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.shares is number && data.shares >= 0 &&
             data.purchasePrice is number && data.purchasePrice >= 0 &&
             data.currentPrice is number && data.currentPrice >= 0;
    }

    // ===============================================================
    // User Rules
    // ===============================================================
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update: if isOwner(uid) && 
        (request.resource.data.role == resource.data.role || isAdmin());
    }

    // ===============================================================
    // Profile Rules
    // ===============================================================
    match /profiles/{profileId} {
      allow read: if (isAuthenticated() && (request.auth.uid in resource.data.members || resource.data.ownerUid == request.auth.uid)) || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isProfileOwner(profileId) || isAdmin();
      allow delete: if isProfileOwner(profileId) || isAdmin();

      // Subcollections
      match /budgets/{budgetId} {
        allow read: if isProfileMember(profileId) || isAdmin();
        allow write: if isProfileMember(profileId) || isAdmin();
      }

      match /transactions/{transactionId} {
        allow read: if isProfileMember(profileId) || isAdmin();
        allow write: if isProfileMember(profileId) || isAdmin();
      }

      match /goals/{goalId} {
        allow read: if isProfileMember(profileId) || isAdmin();
        allow write: if isProfileMember(profileId) || isAdmin();
      }

      match /investments/{investmentId} {
        allow read: if isProfileMember(profileId) || isAdmin();
        allow create: if isProfileMember(profileId) && isValidInvestment(request.resource.data);
        allow update: if isProfileMember(profileId) && isValidInvestment(request.resource.data);
        allow delete: if isProfileMember(profileId);
      }
    }
  }
}
